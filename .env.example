# Copia este archivo como .env y rellena los valores con los de tu proyecto Supabase
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-clave-anonima-aqui

# Opcional: email de confirmación automático al cliente tras firmar
# Regístrate gratis en resend.com, crea un API key y pégalo aquí
VITE_RESEND_API_KEY=
